# Manga Dashboard 后端环境变量配置示例
# 复制本文件为 .env，并填写实际值

# ==================== 安全配置 ====================

# JWT 签名密钥（必须设置！建议使用 openssl rand -hex 32 生成）
# 不设置时，每次重启都会生成新密钥，导致所有已登录 Token 失效
JWT_SECRET_KEY=your-super-secret-key-change-me-in-production

# 首次初始化时的管理员密码
# 若不设置，首次启动时会随机生成并打印到控制台
# 注意：仅在 data.db 不存在时生效
ADMIN_PASSWORD=

# ==================== CORS 跨域配置 ====================

# 允许访问的前端源，多个用逗号分隔
# 例如: http://localhost:5173,https://your-domain.com
# 不设置时默认允许所有来源（仅适合本地开发）
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
